@{
    Layout = null;
    ViewData["Title"] = "About";
}

<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="utf-8" />
    <title>About - KPI System</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: radial-gradient(circle at top, #1e293b, #020617);
            color: white;
        }

        .navbar {
            backdrop-filter: blur(10px);
            background: rgba(255,255,255,0.05);
            border-radius: 15px;
            margin: 20px;
        }

        .nav-link {
            color: #cbd5f5 !important;
            transition: 0.3s;
        }

            .nav-link:hover {
                color: white !important;
                transform: translateY(-2px);
            }

        .logo {
            font-weight: 700;
            font-size: 22px;
            color: #38bdf8;
        }

        .hero {
            text-align: center;
            padding: 90px 20px 50px;
        }

            .hero h1 {
                font-size: 46px;
                font-weight: 700;
                letter-spacing: 1px;
            }

            .hero p {
                color: #94a3b8;
                font-size: 18px;
            }

        .glass-card {
            background: rgba(255,255,255,0.05);
            border-radius: 22px;
            padding: 35px;
            backdrop-filter: blur(18px);
            box-shadow: 0 10px 50px rgba(0,0,0,0.5);
            transition: 0.3s;
            height: 100%;
        }

            .glass-card:hover {
                transform: translateY(-10px);
            }

        .section-title {
            font-weight: 700;
            font-size: 20px;
            margin-bottom: 15px;
            color: #38bdf8;
        }

        .highlight {
            color: #cbd5f5;
            line-height: 1.7;
        }

        ul {
            padding-left: 18px;
            color: #cbd5f5;
        }

        li {
            margin-bottom: 8px;
        }
    </style>
</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark px-4">
        <div class="container-fluid">
            <a class="navbar-brand logo" asp-controller="Home" asp-action="Index">
                KPI<span style="color:#94a3b8;">.uz</span>
            </a>

            <div class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" asp-action="KPI">KPI tizimi</a></li>
                    <li class="nav-item"><a class="nav-link" asp-action="Opportunities">Imkoniyatlar</a></li>
                    <li class="nav-item"><a class="nav-link active" asp-action="About">Tizim haqida</a></li>
                    <li class="nav-item"><a class="nav-link" asp-action="FAQ">Savollar</a></li>
                    <li class="nav-item"><a class="nav-link" asp-action="Contact">Bog‘lanish</a></li>
                    <li class="nav-item">
                        <a class="btn btn-outline-light ms-3 px-3" asp-controller="Login" asp-action="Index">Kirish</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="hero animate__animated animate__fadeInDown">
        <h1>ℹ️ KPI Platformasi</h1>
        <p>Samaradorlikni baholash va boshqarish uchun zamonaviy tizim</p>
    </div>

    <div class="container pb-5">
        <div class="row g-4">

            <div class="col-md-6 animate__animated animate__fadeInUp">
                <div class="glass-card">
                    <div class="section-title">🎯 Maqsad</div>
                    <div class="highlight">
                        KPI tizimi pedagoglar va administratorlar faoliyatini aniq, shaffof va samarali baholash uchun yaratilgan.
                        U ish jarayonini tahlil qilish, rivojlantirish va nazorat qilish imkonini beradi.
                    </div>
                </div>
            </div>

            <div class="col-md-6 animate__animated animate__fadeInUp">
                <div class="glass-card">
                    <div class="section-title">🚀 Imkoniyatlar</div>
                    <ul>
                        <li>Blog yaratish va boshqarish</li>
                        <li>Hujjatlarni yuklash va tekshirish</li>
                        <li>KPI ball tizimi orqali baholash</li>
                        <li>Administrator nazorati va tasdiqlash</li>
                    </ul>
                </div>
            </div>

        </div>
    </div>

</body>
</html>