@{
    Layout = null;
    ViewData["Title"] = "Contact";
}

<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="utf-8" />
    <title>Contact</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: radial-gradient(circle at top, #1e293b, #020617);
            color: white;
        }

        .navbar {
            backdrop-filter: blur(10px);
            background: rgba(255,255,255,0.05);
            border-radius: 15px;
            margin: 20px;
        }

        .nav-link {
            color: #cbd5f5 !important;
        }

            .nav-link:hover {
                color: white !important;
            }

        .logo {
            font-weight: 700;
            color: #38bdf8;
        }

        .hero {
            text-align: center;
            padding: 80px 20px 40px;
        }

        .glass-card {
            background: rgba(255,255,255,0.05);
            border-radius: 20px;
            padding: 30px;
            backdrop-filter: blur(15px);
            box-shadow: 0 8px 40px rgba(0,0,0,0.4);
            transition: 0.3s;
            height: 100%;
        }

            .glass-card:hover {
                transform: translateY(-5px);
            }

        .contact-item {
            display: flex;
            align-items: center;
            margin-bottom: 15px;
        }

        .contact-icon {
            width: 45px;
            height: 45px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 10px;
            background: linear-gradient(45deg,#3b82f6,#06b6d4);
        }

        .location-icon {
            font-size: 80px;
            background: linear-gradient(45deg,#3b82f6,#06b6d4);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
    </style>
</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark px-4">
        <div class="container-fluid">
            <a class="navbar-brand logo" asp-controller="Home" asp-action="Index">
                KPI<span style="color:#94a3b8;">.uz</span>
            </a>

            <div class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" asp-action="KPI">KPI tizimi</a></li>
                    <li class="nav-item"><a class="nav-link" asp-action="Opportunities">Imkoniyatlar</a></li>
                    <li class="nav-item"><a class="nav-link" asp-action="About">Tizim haqida</a></li>
                    <li class="nav-item"><a class="nav-link" asp-action="FAQ">Savollar</a></li>
                    <li class="nav-item"><a class="nav-link active" asp-action="Contact">Bog‘lanish</a></li>
                    <li class="nav-item">
                        <a class="btn btn-outline-light ms-3 px-3" asp-controller="Login" asp-action="Index">
                            Kirish
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="hero animate__animated animate__fadeInDown">
        <h1>📞 Biz bilan bog‘laning</h1>
        <p class="fs-5">Savollaringiz bo‘lsa, bizga murojaat qiling</p>
    </div>

    <div class="container pb-5">
        <div class="row g-4 align-items-stretch">

            <div class="col-md-6 d-flex animate__animated animate__fadeInLeft">
                <div class="glass-card w-100">
                    <h4 class="mb-4">📌 Kontakt ma’lumotlar</h4>

                    <div class="contact-item">
                        <div class="contact-icon"><i class="fa fa-envelope"></i></div>
                        <div>xayotbekdeveloper@gmail.com</div>
                    </div>

                    <div class="contact-item">
                        <div class="contact-icon"><i class="fa fa-phone"></i></div>
                        <div>+998 77 978 25 25</div>
                    </div>

                    <div class="contact-item">
                        <div class="contact-icon">
                            <i class="fa-brands fa-telegram"></i>
                        </div>
                        <div>t.me/xayotbek</div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 d-flex animate__animated animate__fadeInRight">
                <div class="glass-card w-100 text-center position-relative overflow-hidden">

                    <div style="
                    position:absolute;
                    width:300px;
                    height:300px;
                    background: radial-gradient(circle, rgba(59,130,246,0.4), transparent);
                    top:-50px;
                    right:-50px;
                    filter: blur(80px);
                "></div>

                    <h4 class="mb-4">📍 Bizning manzil</h4>

                    <div class="location-icon">
                        <i class="fa fa-location-dot"></i>
                    </div>

                    <h2 class="mt-3 fw-bold">Toshkent</h2>
                    <p class="text-secondary fs-5">Uzbekistan</p>

                </div>
            </div>

        </div>
    </div>

</body>
</html>