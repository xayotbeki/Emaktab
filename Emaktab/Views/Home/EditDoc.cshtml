@model Document100

@{
    ViewBag.Title = "Hujjatni tahrirlash";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
<link rel="stylesheet" href="~/assets/vendor_components/font-awesome/css/font-awesome.min.css" asp-append-version="true">
<link rel="stylesheet" href="~/assets/vendor_components/bootstrap/dist/css/bootstrap.css" asp-append-version="true">

<style>
    .form-section {
        background-color: #ffffff;
        border-radius: 1rem;
        padding: 2rem;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
        max-width: 800px;
        margin: auto;
    }

        .form-section h3 {
            font-weight: 600;
            margin-bottom: 1.5rem;
        }

    .form-label {
        font-weight: 500;
    }

    .btn-icon {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .input-group .form-control[readonly] {
        background-color: #f1f1f1;
    }
</style>

<div class="container-fluid py-5">
    <div class="form-section">
        <h3><i class="bi bi-pencil-square me-2"></i> Hujjatni tahrirlash</h3>

        <form method="post" enctype="multipart/form-data" asp-action="EditDoc">
            <input type="hidden" name="Id" value="@Model.Id" />

            <div class="mb-3">
                <label class="form-label">✏️ Izoh</label>
                <input type="text" name="Comment" class="form-control" value="@Model.Comment" required />
            </div>

            <div class="mb-3">
                <label class="form-label">📅 Sana</label>
                <input type="date" name="create_date" class="form-control"
                       value="@Model.create_date.ToString("yyyy-MM-dd")" required />
            </div>

            <div class="mb-3">
                <label class="form-label">📎 Joriy fayl</label>
                <div class="input-group">
                    <input type="text" class="form-control" readonly
                           value="@System.IO.Path.GetFileName(Model.FilePath)" />
                    @if (!string.IsNullOrEmpty(Model.FilePath))
                    {
                        <a href="@Url.Content(Model.FilePath)" class="btn btn-success" target="_blank">
                            <i class="bi bi-download"></i> Yuklab olish
                        </a>
                    }
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">🆕 Yangi fayl yuklash (ixtiyoriy)</label>
                <input type="file" name="UploadDocument" class="form-control" />
            </div>

            <div class="d-flex justify-content-end gap-3 mt-4">
                <a asp-action="ImportDoc" class="btn btn-outline-secondary btn-icon">
                    <i class="bi bi-arrow-left-circle"></i> Bekor qilish
                </a>
                <button type="submit" class="btn btn-primary btn-icon">
                    <i class="bi bi-save"></i> Saqlash
                </button>
            </div>
        </form>
    </div>
</div>
