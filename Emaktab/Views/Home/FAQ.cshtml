@{
    Layout = null;
    ViewData["Title"] = "FAQ";
}

<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="utf-8" />
    <title>FAQ</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: radial-gradient(circle at top, #1e293b, #020617);
            color: white;
        }

        .navbar {
            backdrop-filter: blur(10px);
            background: rgba(255,255,255,0.05);
            border-radius: 15px;
            margin: 20px;
        }

        .nav-link {
            color: #cbd5f5 !important;
        }

            .nav-link:hover {
                color: white !important;
            }

        .logo {
            font-weight: 700;
            color: #38bdf8;
        }

        .hero {
            text-align: center;
            padding: 80px 20px 40px;
        }

        .accordion-item {
            background: rgba(255,255,255,0.05);
            border: none;
            border-radius: 15px;
            margin-bottom: 15px;
            overflow: hidden;
        }

        .accordion-button {
            background: transparent;
            color: white;
            font-weight: 500;
        }

            .accordion-button:not(.collapsed) {
                background: rgba(59,130,246,0.2);
                color: white;
            }

        .accordion-body {
            color: #cbd5f5;
        }

    </style>
</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark px-4">
        <div class="container-fluid">
            <a class="navbar-brand logo" asp-controller="Home" asp-action="Index">
                KPI<span style="color:#94a3b8;">.uz</span>
            </a>

            <div class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto">

                    <li class="nav-item"><a class="nav-link" asp-action="KPI">KPI tizimi</a></li>
                    <li class="nav-item"><a class="nav-link" asp-action="Opportunities">Imkoniyatlar</a></li>
                    <li class="nav-item"><a class="nav-link" asp-action="About">Tizim haqida</a></li>
                    <li class="nav-item"><a class="nav-link active" asp-action="FAQ">Savollar</a></li>
                    <li class="nav-item"><a class="nav-link" asp-action="Contact">Bog‘lanish</a></li>
                    <li class="nav-item">
                        <a class="btn btn-outline-light ms-3 px-3" asp-controller="Login" asp-action="Index">
                            Kirish
                        </a>
                    </li>

                </ul>
            </div>
        </div>
    </nav>

    <div class="hero animate__animated animate__fadeInDown">
        <h1>❓ Ko‘p so‘raladigan savollar</h1>
        <p class="fs-5">Foydalanuvchilar eng ko‘p beradigan savollar va javoblar</p>
    </div>

    <div class="container pb-5">
        <div class="accordion animate__animated animate__fadeInUp" id="faqAccordion">

            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button" data-bs-toggle="collapse" data-bs-target="#q1">
                        KPI nima?
                    </button>
                </h2>
                <div id="q1" class="accordion-collapse collapse show">
                    <div class="accordion-body">
                        KPI — bu samaradorlikni baholash tizimi bo‘lib, xodimlar faoliyatini o‘lchash va tahlil qilish imkonini beradi.
                    </div>
                </div>
            </div>

            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#q2">
                        Blog nima uchun kerak?
                    </button>
                </h2>
                <div id="q2" class="accordion-collapse collapse">
                    <div class="accordion-body">
                        Blog pedagoglarning ilmiy faoliyatini ko‘rsatish va baholash uchun ishlatiladi.
                    </div>
                </div>
            </div>

            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#q3">
                        Kim tasdiqlaydi?
                    </button>
                </h2>
                <div id="q3" class="accordion-collapse collapse">
                    <div class="accordion-body">
                        Barcha ma’lumotlar administrator tomonidan tekshiriladi va tasdiqlanadi.
                    </div>
                </div>
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>