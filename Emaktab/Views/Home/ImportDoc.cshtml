                                    data-bs-toggle="collapse"
                                    data-bs-target="#specialistInfoCollapse"
                                    aria-expanded="true"
                                    aria-controls="specialistInfoCollapse"
                                    onclick="toggleIcon(this)">
                                <span class="d-flex align-items-center">
                                    <i class="bi bi-chevron-down me-2"></i>
                                    1. Kutubxona bo‘yicha mutaxassislik ma’lumotiga ega bo‘lishi (<strong>10 ball</strong>)
                                </span>
                                <span class="ms-auto">
                                    <span class="text-success">10/</span>
                                    <span class="text-danger">0</span>
                                </span>
                            </button>

                            <div id="specialistInfoCollapse"
                                 class="accordion-collapse collapse"
                                 data-bs-parent="#accordionFlushExample1">
                                <div class="accordion-body">
                                    <div class="accordion" id="subAccordion">
                                        <div class="accordion-item">
                                            <h2 class="accordion-header">
                                                <button class="accordion-button collapsed d-flex justify-content-between align-items-center"
                                                        type="button"
                                                        data-bs-toggle="collapse"
                                                        data-bs-target="#nonSpecialistCollapse"
                                                        aria-expanded="true"
                                                        aria-controls="nonSpecialistCollapse"
                                                        onclick="toggleIcon(this)">
                                                    <span class="d-flex align-items-center">
                                                        <i class="bi bi-chevron-down me-2"></i>
                                                        1.1 Nomutaxassislar (<strong>0 ball</strong>)
                                                    </span>
                                                    <span class="ms-auto">
                                                        <span class="text-success">0/</span>
                                                        <span class="text-danger">0</span>
                                                    </span>
                                                </button>
                                            </h2>

                                            <div id="nonSpecialistCollapse"
                                                 class="accordion-collapse collapse"
                                                 data-bs-parent="#subAccordion">
                                                <div class="accordion-body">
                                                    <form asp-action="CreateDoc" method="post" enctype="multipart/form-data">
                                                        <input type="hidden" name="DocumentTypeId" value="11" />
