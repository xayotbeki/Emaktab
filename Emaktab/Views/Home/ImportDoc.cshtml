                                                                </tr>
                                                            </thead>
                                                            <tbody id="nonSpecialistTableBody" style="background-color: aliceblue">
                                                                @{
                                                                    var model = Model.Where(x => x.DocumentTypeId == 12).ToList();
                                                                    if (model.Count > 0)
                                                                    {
                                                                        foreach (var item in model)
                                                                        {
                                                                            <tr>
                                                                                <td class="text-center">@item.Id</td>
                                                                                <td>@item.Comment</td>
                                                                                <td class="text-center">
                                                                                    @switch (item.status_id)
