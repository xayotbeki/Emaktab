                                                            <div class="row g-2 d-flex justify-content-center align-items-center">
                                                                <div class="col-md-8">
                                                                    <div class="row g-2">
                                                                        <div class="col-md-4">
                                                                            <input type="text" name="Comment" class="form-control" placeholder="Izoh" />
                                                                        </div>
                                                                        <div class="col-md-4">
                                                                            <input type="date" name="CreateDate" class="form-control" />
                                                                        </div>
                                                                        <div class="col-md-4">
                                                                            <label for="fileUpload"
                                                                                   class="btn btn-outline-primary file-upload w-100 h-100 px-3 d-flex align-items-center justify-content-center">
                                                                                <i class="fa fa-upload me-2"></i> Fayl yuklash
                                                                            </label>
                                                                            <input type="file" name="UploadDocument" id="fileUpload" class="d-none" />
                                                                        </div>
                                                                    </div>
                                                                </div>

                                                                <div class="col-md-4 d-flex justify-content-center gap-2">
                                                                    <button type="submit" class="btn btn-primary px-4 d-flex align-items-center">
                                                                        <i class="fa fa-save me-2"></i> Saqlash
                                                                    </button>

                                                                    <button type="submit" name="status_id" value="1" class="btn btn-success px-4 d-flex align-items-center">
                                                                        <i class="fa fa-paper-plane me-2"></i> Yuborish
                                                                    </button>
                                                                </div>
                                                            </div>


