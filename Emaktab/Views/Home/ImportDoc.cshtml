                                                                    <tr>
                                                                        <th style="border: 1px solid #ccc; text-align: center; width: 5%;">#</th>
                                                                        <th style="border: 1px solid #ccc; text-align: center; width: 15%;">Izoh</th>
                                                                        <th style="border: 1px solid #ccc; text-align: center; width: 15%;">Holati</th>
                                                                        <th style="border: 1px solid #ccc; text-align: center; width: 10%;">Ball</th>
                                                                        <th style="border: 1px solid #ccc; text-align: center; width: 20%;">Sana</th>
                                                                        <th style="border: 1px solid #ccc; text-align: center; width: 35%;">Tahrirlash</th>
                                                                    </tr>
                                                                </thead>
                                                                <tbody id="nonSpecialistTableBody" style="background-color: aliceblue">
                                                                    @{
                                                                        var model = Model.Where(x => x.DocumentTypeId == 11).ToList();
                                                                        if (model.Count > 0)
                                                                        {
                                                                            foreach (var item in model)
                                                                            {
                                                                                <tr>
                                                                                    <td class="text-center">@item.Id</td>
                                                                                    <td>@item.Comment</td>
                                                                                    <td class="text-center">
                                                                                        @switch (item.status_id)
                                                                                        {
                                                                                            case (int)DocStatus.Saqlangan:
                                                                                                <span class="badge bg-info rounded-pill px-3 py-2">
                                                                                                    <i class="bi bi-pencil-fill me-1"></i> Saqlangan
                                                                                                </span>
                                                                                                break;
                                                                                            case (int)DocStatus.Yuborilgan:
                                                                                                <span class="badge bg-success rounded-pill px-3 py-2">
                                                                                                    <i class="bi bi-send-check-fill me-1"></i> Yuborilgan
                                                                                                </span>
                                                                                                break;
                                                                                            default:
                                                                                                <span class="badge bg-warning text-dark rounded-pill px-3 py-2">
                                                                                                    <i class="bi bi-question-circle-fill me-1"></i> Noma'lum
                                                                                                </span>
                                                                                                break;
                                                                                        }
                                                                                    </td>
                                                                                    <td class="text-center">@item.Score</td>
                                                                                    <td class="text-center">@item.upload_date.ToString("dd.MM.yyyy")</td>
                                                                                    <td class="text-center">
                                                                                        <div class="d-flex justify-content-center flex-wrap gap-2">
                                                                                            <a asp-action="DetailsDoc" asp-route-Id="@item.Id" class="btn btn-info text-white rounded-2 shadow d-flex align-items-center px-2 py-1"
                                                                                               title="Ko'rish">
                                                                                                <i class="bi bi-eye-fill me-2 fs-6"></i> Ko‘rish
                                                                                            </a>

                                                                                            @if (item.status_id == (int)DocStatus.Saqlangan)
                                                                                            {
                                                                                                <a asp-action="EditStatusDoc" asp-route-statusId="1" asp-route-docId="@item.Id"
                                                                                                   class="btn btn-success rounded-2 shadow d-flex align-items-center px-2 py-1"
                                                                                                   title="Yuborish">
                                                                                                    <i class="bi bi-send-fill me-2 fs-6"></i> Yuborish
                                                                                                </a>

                                                                                                <a class="btn btn-danger rounded-2 shadow d-flex align-items-center px-2 py-1"
                                                                                                   title="O‘chirish"
                                                                                                   onclick="return confirm('Haqiqatan ham ushbu blogni o‘chirmoqchimisiz?');">
                                                                                                    <i class="bi bi-trash-fill me-2 fs-6"></i> O‘chirish
                                                                                                </a>

                                                                                                <a asp-action="EditDoc" asp-route-Id="@item.Id"
                                                                                                   class="btn btn-warning rounded-2 shadow d-flex align-items-center px-2 py-1 text-white"
                                                                                                   title="Tahrirlash">
                                                                                                    <i class="bi bi-pencil-fill me-2 fs-6"></i> Tahrirlash
                                                                                                </a>
                                                                                            }
                                                                                        </div>
                                                                                    </td>


                                                                                </tr>
                                                                            }
                                                                        }
                                                                        else
                                                                        {
                                                                            <tr>
                                                                                <td colspan="6" class="text-center text-muted">
                                                                                    <i class="fa fa-file"></i> <br />Ma'lumot yo‘q
                                                                                </td>
                                                                            </tr>
                                                                        }
                                                                    }
                                                                </tbody>

                                                            </table>
                                                        </div>
                                                    </form>

                                                </div>
                                            </div>
                                        </div>
                                    </div>
