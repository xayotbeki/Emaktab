@model List<Document100>

@{
    ViewData["Title"] = "Pedagog baholash";
}

<style>
    body {
        background-color: #f4f6f9;
        font-family: 'Segoe UI', sans-serif;
    }

    .card {
        border-radius: 12px;
        border: none;
        box-shadow: 0 4px 15px rgba(0,0,0,0.08);
    }

    .card-header {
        border-radius: 12px 12px 0 0 !important;
        font-weight: 600;
        letter-spacing: 0.3px;
    }

    .table {
        border-radius: 10px;
        overflow: hidden;
    }

        .table thead {
            background-color: #1a3a6c;
            color: #fff;
        }

        .table tbody tr:hover {
            background-color: #f1f5fb;
            transition: 0.2s;
        }

    .form-control {
        border-radius: 8px;
        box-shadow: none;
        border: 1px solid #ddd;
        transition: 0.2s;
    }

        .form-control:focus {
            border-color: #0d6efd;
            box-shadow: 0 0 5px rgba(13,110,253,0.2);
        }

    .btn {
        border-radius: 8px;
        transition: 0.2s;
    }

        .btn:hover {
            transform: scale(1.03);
        }

    .badge {
        padding: 6px 10px;
        border-radius: 8px;
        font-size: 12px;
    }

    .bg-red {
        background-color: #dc3545;
        color: #fff;
    }

    .alert {
        border-radius: 10px;
    }

    h4 {
        font-weight: 600;
    }
</style>

@if (TempData["successMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["successMessage"]
    </div>
}

@if (TempData["errorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["errorMessage"]
    </div>
}

<div class="container-fluid my-4">
    <div class="card">
        <div class="card-header text-white" style="background-color:#1a3a6c;">
            <h4 class="mb-0">Pedagog xodimlarining faoliyatini 100 ballik tizimda baholash</h4>
        </div>

        <div class="card-body">
            <div class="row mb-4">
                <div class="col-md-4 text-center">
                    <strong>O‘quv yili:</strong> 2025/2026
                </div>
                <div class="col-md-4 text-center">
                    <strong>Maksimal ball:</strong> 100
                </div>
                <div class="col-md-4 text-center">
                    <strong>To‘plangan ball:</strong>
                    <h4 class="badge bg-success">
                        @Model.Sum(x => x.Score)
                    </h4>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header bg-light">
                    1. Malaka oshirish sertifikati (15 ball)
                </div>
                <div class="card-body">

                    <form asp-action="CreateDoc" method="post" enctype="multipart/form-data">
                        <input type="hidden" name="DocumentTypeId" value="101" />
                        <input type="hidden" name="CategoryId" value="1" />

                        <div class="row g-2">
                            <div class="col-md-4">
                                <input type="text" name="Comment" class="form-control" placeholder="Izoh" />
                            </div>
                            <div class="col-md-4">
                                <input type="date" name="create_date" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <input type="file" name="UploadDocument" class="form-control" />
                            </div>
                        </div>

                        <div class="mt-3">
                            <button type="submit" name="status_id" value="1" class="btn btn-success">
                                Yuborish
                            </button>
                        </div>
                    </form>

                    <table class="table table-bordered table-striped mt-4">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Izoh</th>
                                <th>Holati</th>
                                <th>Ball</th>
                                <th>Sana</th>
                                <th>Amallar</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var docs101 = Model.Where(x => x.DocumentTypeId == 101).ToList();
                            }

                            @if (docs101.Any())
                            {
                                foreach (var item in docs101)
                                {
                                    <tr>
                                        <td>@item.Id</td>
                                        <td>@item.Comment</td>
                                        <td>
                                            @if (item.status_id == (int)DocStatus.Saqlangan)
                                            {
                                                <span class="badge bg-info">Saqlangan</span>
                                            }
                                            else if (item.status_id == (int)DocStatus.Yuborilgan)
                                            {
                                                <span class="badge bg-primary">Yuborilgan</span>
                                            }
                                            else if (item.status_id == (int)DocStatus.QabulQilindi)
                                            {
                                                <span class="badge bg-success">Qabul qilindi</span>
                                            }
                                            else if (item.status_id == (int)DocStatus.Qaytarildi)
                                            {
                                                <span class="badge bg-red">Qaytarildi</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning text-dark">Noma'lum</span>
                                            }
                                        </td>
                                        <td>@item.Score</td>
                                        <td>@item.upload_date.ToString("dd.MM.yyyy")</td>
                                        <td>
                                            <a asp-action="DetailsDoc" asp-route-id="@item.Id" class="btn btn-info btn-sm">Ko‘rish</a>

                                            @if (item.status_id == (int)DocStatus.Saqlangan)
                                            {
                                                <a asp-action="EditDoc" asp-route-id="@item.Id" class="btn btn-warning btn-sm text-white">Tahrirlash</a>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted">Ma'lumot yo‘q</td>
                                </tr>
                            }
                        </tbody>
                    </table>

                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header bg-light">
                    2. Ilmiy maqola (15 ball)
                </div>
                <div class="card-body">

                    <form asp-action="CreateDoc" method="post" enctype="multipart/form-data">
                        <input type="hidden" name="DocumentTypeId" value="102" />
                        <input type="hidden" name="CategoryId" value="2" />

                        <div class="row g-2">
                            <div class="col-md-4">
                                <input type="text" name="Comment" class="form-control" placeholder="Izoh" />
                            </div>
                            <div class="col-md-4">
                                <input type="date" name="create_date" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <input type="file" name="UploadDocument" class="form-control" />
                            </div>
                        </div>

                        <div class="mt-3">
                            <button type="submit" name="status_id" value="1" class="btn btn-success">
                                Yuborish
                            </button>
                        </div>
                    </form>

                    <table class="table table-bordered table-striped mt-4">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Izoh</th>
                                <th>Holati</th>
                                <th>Ball</th>
                                <th>Sana</th>
                                <th>Amallar</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var docs102 = Model.Where(x => x.DocumentTypeId == 102).ToList();
                            }

                            @if (docs102.Any())
                            {
                                foreach (var item in docs102)
                                {
                                    <tr>
                                        <td>@item.Id</td>
                                        <td>@item.Comment</td>
                                        <td>
                                            @if (item.status_id == (int)DocStatus.Saqlangan)
                                            {
                                                <span class="badge bg-info">Saqlangan</span>
                                            }
                                            else if (item.status_id == (int)DocStatus.Yuborilgan)
                                            {
                                                <span class="badge bg-primary">Yuborilgan</span>
                                            }
                                            else if (item.status_id == (int)DocStatus.QabulQilindi)
                                            {
                                                <span class="badge bg-success">Qabul qilindi</span>
                                            }
                                            else if (item.status_id == (int)DocStatus.Qaytarildi)
                                            {
                                                <span class="badge bg-red">Qaytarildi</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning text-dark">Noma'lum</span>
                                            }
                                        </td>
                                        <td>@item.Score</td>
                                        <td>@item.upload_date.ToString("dd.MM.yyyy")</td>
                                        <td>
                                            <a asp-action="DetailsDoc" asp-route-id="@item.Id" class="btn btn-info btn-sm">
                                                Ko‘rish
                                            </a>

                                            @if (item.status_id == (int)DocStatus.Saqlangan)
                                            {
                                                <a asp-action="EditDoc" asp-route-id="@item.Id"
                                                   class="btn btn-warning btn-sm text-white">
                                                    Tahrirlash
                                                </a>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted">
                                        Ma'lumot yo‘q
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>

                </div>
            </div>

        </div>
    </div>
</div>