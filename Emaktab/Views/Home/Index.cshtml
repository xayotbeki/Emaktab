@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KPI | Platforma</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: radial-gradient(circle at top, #1e293b, #020617);
            height: 100vh;
            overflow: hidden;
            color: white;
        }

        .navbar {
            backdrop-filter: blur(10px);
            background: rgba(255,255,255,0.05);
            border-radius: 15px;
            margin: 20px;
        }

        .nav-link {
            color: #ccc !important;
            transition: 0.3s;
        }

            .nav-link:hover {
                color: #fff !important;
                transform: translateY(-2px);
            }

        .logo {
            font-weight: 700;
            font-size: 22px;
            color: #38bdf8;
        }

        .hero {
            height: 90vh;
            display: flex;
            align-items: center;
        }

            .hero h1 {
                font-size: 48px;
                font-weight: 700;
                line-height: 1.3;
            }

            .hero p {
                color: #94a3b8;
                margin-top: 15px;
            }

        .btn-custom {
            padding: 12px 25px;
            border-radius: 12px;
            font-weight: 500;
            transition: 0.3s;
        }

        .btn-primary {
            background: linear-gradient(45deg, #3b82f6, #06b6d4);
            border: none;
        }

            .btn-primary:hover {
                transform: translateY(-3px);
                box-shadow: 0 10px 25px rgba(59,130,246,0.5);
            }

        .glass-box {
            background: rgba(255,255,255,0.05);
            border-radius: 20px;
            padding: 40px;
            backdrop-filter: blur(15px);
            box-shadow: 0 8px 40px rgba(0,0,0,0.4);
        }

        .floating {
            animation: float 4s ease-in-out infinite;
        }

        @@keyframes float {
            0% {
                transform: translateY(0px);
            }

            50% {
                transform: translateY(-10px);
            }

            100% {
                transform: translateY(0px);
            }
        }

    </style>
</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark px-4">
        <div class="container-fluid">
            <a class="navbar-brand logo" asp-controller="Home" asp-action="Index">
                KPI<span style="color:#94a3b8;">.uz</span>
            </a>

            <div class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto">

                    <li class="nav-item"><a class="nav-link" asp-action="KPI">KPI tizimi</a></li>
                    <li class="nav-item"><a class="nav-link" asp-action="Opportunities">Imkoniyatlar</a></li>
                    <li class="nav-item"><a class="nav-link" asp-action="About">Tizim haqida</a></li>
                    <li class="nav-item"><a class="nav-link" asp-action="FAQ">Savollar</a></li>
                    <li class="nav-item"><a class="nav-link" asp-action="Contact">Bog‘lanish</a></li>

                </ul>
            </div>
        </div>
    </nav>

    <div class="container hero">
        <div class="row w-100 align-items-center">

            <div class="col-md-6 animate__animated animate__fadeInLeft">
                <h1>
                    Tashkilot samaradorligini <br>
                    yangi bosqichga olib chiqing 🚀
                </h1>

                <p class="fs-5">
                    KPI UP platformasi orqali xodimlar faoliyatini nazorat qiling,
                    tahlil qiling va rivojlantiring.
                </p>

                <div class="mt-4">
                    <a asp-action="Index" asp-controller="Login" class="btn btn-primary btn-custom me-3">
                        Tizimga kirish
                    </a>

                    <a asp-action="Register" asp-controller="Login" class="btn btn-outline-light btn-custom">
                        Ro‘yxatdan o‘tish
                    </a>
                </div>
            </div>

            <div class="col-md-6 animate__animated animate__fadeInRight">
                <div class="glass-box text-center floating">
                    <h4 class="mb-3">📊 KPI Monitoring</h4>
                    <p>
                        Real vaqt rejimida natijalarni kuzating va
                        samaradorlikni oshiring.
                    </p>

                    <hr style="border-color: rgba(255,255,255,0.1);">

                    <h5>✔ Statistik tahlil</h5>
                    <h5>✔ Avtomatik hisobot</h5>
                    <h5>✔ Xodimlar monitoringi</h5>
                </div>
            </div>

        </div>
    </div>

</body>
</html>