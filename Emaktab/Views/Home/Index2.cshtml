@{
    ViewData["Title"] = "Pedagog panel";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    body {
        background: linear-gradient(120deg, #eef2f7, #f8fbff);
        font-family: 'Segoe UI', sans-serif;
    }

    .dashboard-header {
        background: linear-gradient(135deg, #1a3a6c, #0d6efd);
        color: white;
        padding: 25px;
        border-radius: 15px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.1);
    }

        .dashboard-header h3 {
            margin: 0;
            font-weight: 600;
        }

    .user-info p {
        margin: 5px 0;
        font-size: 15px;
    }

    .box {
        border-radius: 15px;
        border: none;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        transition: all 0.3s ease;
        background: white;
        overflow: hidden;
    }

        .box:hover {
            transform: translateY(-8px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.12);
        }

    .box-body {
        padding: 25px;
    }

    .icon-box {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 15px;
        font-size: 28px;
        color: white;
    }

    .bg-blue {
        background: linear-gradient(135deg, #0d6efd, #0dcaf0);
    }

    .bg-orange {
        background: linear-gradient(135deg, #ff9800, #ffc107);
    }

    .btn-custom {
        border-radius: 10px;
        padding: 7px 18px;
        font-weight: 500;
        transition: 0.3s;
    }

        .btn-custom:hover {
            transform: scale(1.05);
        }

    .card-title {
        font-weight: 600;
        margin-bottom: 10px;
    }

    .muted-text {
        color: #777;
        font-size: 14px;
    }

    .content-wrapper {
        margin-top: 20px;
    }
</style>

<section class="content">
    <div class="container-fluid content-wrapper">

        <div class="dashboard-header mb-4">
            <h3>👨‍🏫 Pedagog paneli</h3>
            <div class="user-info mt-3">
                <p><strong>F.I.O:</strong> @ViewBag.user_fio</p>
                <p><strong>Foydalanuvchi turi:</strong> @ViewBag.usertype_name</p>
                <p><strong>Login:</strong> @Context.Session.GetString("UserLogin")</p>
            </div>
        </div>

        <div class="row g-4">

            <div class="col-xl-6 col-md-6 col-12">
                <div class="box">
                    <div class="box-body text-center">
                        <div class="icon-box bg-blue">
                            <i class="fa fa-book"></i>
                        </div>

                        <h4 class="card-title">Darslarim</h4>
                        <p class="muted-text">
                            Sizga tegishli darslar va ish rejalari
                        </p>

                        <a asp-action="IshReja"
                           asp-controller="Home"
                           class="btn btn-primary btn-custom">
                            Ko‘rish
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-xl-6 col-md-6 col-12">
                <div class="box">
                    <div class="box-body text-center">
                        <div class="icon-box bg-orange">
                            <i class="fa fa-bar-chart"></i>
                        </div>

                        <h4 class="card-title">
                            KPI natija: @ViewBag.TotalScore ball
                        </h4>

                        <p class="muted-text">
                            Sizning umumiy samaradorlik ko‘rsatkichlaringiz
                        </p>

                        <a asp-action="ImportDocPed"
                           class="btn btn-warning btn-custom text-white">
                            Ko‘rish
                        </a>
                    </div>
                </div>
            </div>

        </div>

    </div>
</section>