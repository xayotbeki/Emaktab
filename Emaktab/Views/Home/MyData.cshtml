@model User;
@{
    ViewData["Title"] = "Ma'lumotlarni o‘zgartirish";
}
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" type="text/css" href="~/assets/vendor_components/font-awesome/css/font-awesome.min.css" asp-append-version="true">
<link rel="stylesheet" href="~/assets/vendor_components/bootstrap/dist/css/bootstrap.css" asp-append-version="true">
<div class="container-fluid d-flex justify-content-center mt-5">
    <div class="card shadow-lg rounded p-4" style=" width: 99.9%;">
        <div class="card-body">
            <div class="text-center mb-4">
                <h4 class="card-title">
                    <i class="fa fa-id-card text-success me-2"></i>Umumiy ma'lumotlar
                </h4>
            </div>
            <form asp-action="EditMyData" method="post">
                <div class="row g-3">
                    <input type="hidden" asp-for="Id" />

                    <div class="col-md-4">
                        <label class="form-label">Familiya</label>
                        <input asp-for="lastname" class="form-control shadow-sm" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Ism</label>
                        <input asp-for="firstname" class="form-control shadow-sm" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Otasining ismi</label>
                        <input asp-for="user_fio" class="form-control shadow-sm" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Email</label>
                        <input asp-for="user_email" class="form-control shadow-sm" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">JSHIR</label>
                        <input asp-for="Pinfl" class="form-control shadow-sm" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Tug'ilgan sana</label>
                        <input asp-for="birthday" type="date" class="form-control shadow-sm" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Telefon 1</label>
                        <input asp-for="phone_number" class="form-control shadow-sm" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Telefon 2</label>
                        <input asp-for="tajribasi" class="form-control shadow-sm" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Manzil</label>
                        <input asp-for="user_location" class="form-control shadow-sm" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Ilmiy unvon</label>
                        <input asp-for="user_level" class="form-control shadow-sm" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Pasport seriya</label>
                        <input asp-for="Pasport_seria" class="form-control shadow-sm" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Pasport raqami</label>
                        <input asp-for="Pasport_number" class="form-control shadow-sm" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">O‘zbek tili (%)</label>
                        <input asp-for="uzb_lang" class="form-control shadow-sm" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Rus tili (%)</label>
                        <input asp-for="rus_lang" class="form-control shadow-sm" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Ingliz tili (%)</label>
                        <input asp-for="eng_lang" class="form-control shadow-sm" />
                    </div>
                </div>

                <div class="text-center mt-4">
                    <button type="submit" class="btn btn-primary px-4"><i class="fa fa-save me-2"></i>Yangilash</button>
                </div>
            </form>
        </div>
    </div>
</div>
@if (TempData["successMessage"] != null)
{
    <div id="success-alert" class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["successMessage"]
    </div>
}
@if (TempData["errorMessage"] != null)
{
    <div id="error-alert" class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["errorMessage"]
    </div>
}

@section Scripts {
    <script>
        setTimeout(function () {
            var success = document.getElementById('success-alert');
            if (success) {
                success.classList.remove('show');
                success.classList.add('fade');
                setTimeout(() => success.remove(), 500);
            }

            var error = document.getElementById('error-alert');
            if (error) {
                error.classList.remove('show');
                error.classList.add('fade');
                setTimeout(() => error.remove(), 500);
            }
        }, 3000);
    </script>
}