@{
    Layout = null;
    ViewData["Title"] = "Opportunities";
}

<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="utf-8" />
    <title>Opportunities</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: radial-gradient(circle at top, #1e293b, #020617);
            color: white;
        }

        .navbar {
            backdrop-filter: blur(10px);
            background: rgba(255,255,255,0.05);
            border-radius: 15px;
            margin: 20px;
        }

        .nav-link {
            color: #cbd5f5 !important;
            transition: 0.3s;
        }

            .nav-link:hover {
                color: white !important;
                transform: translateY(-2px);
            }

        .logo {
            font-weight: 700;
            font-size: 22px;
            color: #38bdf8;
        }

        .hero {
            text-align: center;
            padding: 80px 20px 40px;
        }

            .hero h1 {
                font-size: 42px;
                font-weight: 700;
            }

            .hero p {
                color: #94a3b8;
            }

        .glass-card {
            background: rgba(255,255,255,0.05);
            border-radius: 20px;
            padding: 30px;
            backdrop-filter: blur(15px);
            box-shadow: 0 8px 40px rgba(0,0,0,0.4);
            transition: 0.3s;
            height: 100%;
        }

            .glass-card:hover {
                transform: translateY(-10px) scale(1.03);
            }

        .icon-box {
            width: 70px;
            height: 70px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 15px;
            margin: 0 auto 15px;
            font-size: 28px;
        }

        .bg-blue {
            background: linear-gradient(45deg,#3b82f6,#06b6d4);
        }

        .bg-yellow {
            background: linear-gradient(45deg,#f59e0b,#fbbf24);
        }

        .bg-green {
            background: linear-gradient(45deg,#10b981,#22c55e);
        }

        .bg-red {
            background: linear-gradient(45deg,#ef4444,#f87171);
        }

    </style>
</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark px-4">
        <div class="container-fluid">
            <a class="navbar-brand logo" asp-controller="Home" asp-action="Index">
                KPI<span style="color:#94a3b8;">.uz</span>
            </a>

            <div class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto">

                    <li class="nav-item"><a class="nav-link" asp-action="KPI">KPI tizimi</a></li>
                    <li class="nav-item"><a class="nav-link active" asp-action="Opportunities">Imkoniyatlar</a></li>
                    <li class="nav-item"><a class="nav-link" asp-action="About">Tizim haqida</a></li>
                    <li class="nav-item"><a class="nav-link" asp-action="FAQ">Savollar</a></li>
                    <li class="nav-item"><a class="nav-link" asp-action="Contact">Bog‘lanish</a></li>
                    <li class="nav-item">
                        <a class="btn btn-outline-light ms-3 px-3" asp-controller="Login" asp-action="Index">
                            Kirish
                        </a>
                    </li>

                </ul>
            </div>
        </div>
    </nav>

    <div class="hero animate__animated animate__fadeInDown">
        <h1>🚀 Platforma imkoniyatlari</h1>
        <p class="fs-5">KPI tizimi orqali siz quyidagi imkoniyatlarga ega bo‘lasiz</p>
    </div>

    <div class="container pb-5">
        <div class="row g-4">

            <div class="col-md-3 animate__animated animate__fadeInUp">
                <div class="glass-card text-center">
                    <div class="icon-box bg-blue">
                        <i class="fa fa-user-plus"></i>
                    </div>
                    <h5>Ro‘yxatdan o‘tish</h5>
                    <p>Shaxsiy profil yaratish va tizimga kirish imkoniyati</p>
                </div>
            </div>

            <div class="col-md-3 animate__animated animate__fadeInUp">
                <div class="glass-card text-center">
                    <div class="icon-box bg-yellow">
                        <i class="fa fa-blog"></i>
                    </div>
                    <h5>Blog yozish</h5>
                    <p>Ilmiy faoliyatingizni blog orqali namoyish eting</p>
                </div>
            </div>

            <div class="col-md-3 animate__animated animate__fadeInUp">
                <div class="glass-card text-center">
                    <div class="icon-box bg-green">
                        <i class="fa fa-check-circle"></i>
                    </div>
                    <h5>Tekshiruv</h5>
                    <p>Admin tomonidan nazorat va tasdiqlash jarayoni</p>
                </div>
            </div>

            <div class="col-md-3 animate__animated animate__fadeInUp">
                <div class="glass-card text-center">
                    <div class="icon-box bg-red">
                        <i class="fa fa-trophy"></i>
                    </div>
                    <h5>KPI ball</h5>
                    <p>Faoliyatingiz asosida avtomatik baholash tizimi</p>
                </div>
            </div>

        </div>
    </div>

</body>
</html>