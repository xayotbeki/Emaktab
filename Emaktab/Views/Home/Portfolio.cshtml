@model User

@{
    ViewData["Title"] = "Portfolio";
}

<style>
    .portfolio-card {
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 5px 25px rgba(0,0,0,0.1);
        transition: 0.3s;
    }

        .portfolio-card:hover {
            transform: translateY(-5px);
        }

    .portfolio-header {
        background: linear-gradient(135deg, #1a3a6c, #2196F3);
        color: white;
        padding: 20px;
        font-weight: 600;
        font-size: 18px;
    }

    .profile-img {
        width: 180px;
        height: 180px;
        object-fit: cover;
        border-radius: 50%;
        border: 5px solid #fff;
        box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        transition: 0.3s;
    }

        .profile-img:hover {
            transform: scale(1.05);
        }

    .user-name {
        font-weight: 600;
        margin-top: 15px;
    }

    .user-role {
        color: #888;
        font-size: 14px;
    }

    .portfolio-table {
        border-radius: 10px;
        overflow: hidden;
    }

        .portfolio-table th {
            background: #f1f5f9;
            color: #333;
            width: 30%;
        }

        .portfolio-table td {
            background: #fff;
        }

        .portfolio-table tr:hover td {
            background: #f9fbfd;
        }

    .fade-in {
        animation: fadeIn 0.6s ease-in-out;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<section class="content fade-in">
    <div class="container mt-4">
        <div class="card portfolio-card">

            <div class="portfolio-header">
                <i class="fa fa-address-book"></i> Mening portfolio
            </div>

            <div class="card-body">
                <div class="row">

                    <div class="col-md-4 text-center mb-4">

                        @if (!string.IsNullOrWhiteSpace(Model.IconPath))
                        {
                            <img src="@Url.Content(Model.IconPath)" alt="User Image"
                                 class="profile-img" />
                        }
                        else
                        {
                            <img src="@Url.Content("~/images/default-user.png")" alt="User Image"
                                 class="profile-img" />
                        }

                        <h4 class="user-name">@Model.user_fio</h4>
                        <p class="user-role">@Model.user_type_name</p>

                    </div>

                    <div class="col-md-8">
                        <table class="table table-bordered portfolio-table">

                            <tr>
                                <th>F.I.O</th>
                                <td>@Model.user_fio</td>
                            </tr>

                            <tr>
                                <th>Ism</th>
                                <td>@Model.firstname</td>
                            </tr>

                            <tr>
                                <th>Familiya</th>
                                <td>@Model.lastname</td>
                            </tr>

                            <tr>
                                <th>Email</th>
                                <td>@Model.user_email</td>
                            </tr>

                            <tr>
                                <th>Telefon</th>
                                <td>@Model.phone_number</td>
                            </tr>

                            <tr>
                                <th>Manzil</th>
                                <td>@Model.user_location</td>
                            </tr>

                            <tr>
                                <th>Daraja</th>
                                <td>@Model.user_level</td>
                            </tr>

                            <tr>
                                <th>Tajriba</th>
                                <td>@Model.tajribasi yil</td>
                            </tr>

                            <tr>
                                <th>Biografiya</th>
                                <td>@Model.Biography</td>
                            </tr>

                        </table>
                    </div>

                </div>
            </div>
        </div>
    </div>
</section>