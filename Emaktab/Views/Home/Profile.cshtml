@model UpdateUserViewModel
@{
    ViewData["Title"] = "Ma'lumotlarni o‘zgartirish";
}
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" type="text/css" href="~/assets/vendor_components/font-awesome/css/font-awesome.min.css" asp-append-version="true">
<link rel="stylesheet" href="~/assets/vendor_components/bootstrap/dist/css/bootstrap.css" asp-append-version="true">

<div class="container-fluid mt-5 d-flex justify-content-center">
    <div class="card shadow-lg p-4" style=" width: 90%;">
        <div class="card-body">
            <h4 class="card-title text-center mb-4"><i class="fa fa-user-circle text-primary me-2"></i>Profilni yangilash</h4>

            <form asp-action="Profile" enctype="multipart/form-data" method="post">
                <input asp-for="Id" type="hidden" />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label"><i class="fa fa-user me-2 text-secondary"></i>Ism:</label>
                        <input asp-for="Firstname" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label"><i class="fa fa-user me-2 text-secondary"></i>Familiya:</label>
                        <input asp-for="Lastname" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label"><i class="fa fa-envelope me-2 text-secondary"></i>Email:</label>
                        <input asp-for="UserEmail" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label"><i class="fa fa-sign-in me-2 text-secondary"></i>Login:</label>
                        <input asp-for="UserLogin" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label"><i class="fa fa-lock me-2 text-secondary"></i>Hozirgi parol:</label>
                        <input asp-for="CurrentPassword" class="form-control" type="password" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label"><i class="fa fa-unlock-alt me-2 text-secondary"></i>Yangi parol:</label>
                        <input asp-for="NewPassword" class="form-control" type="password" required/>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label"><i class="fa fa-image me-2 text-secondary"></i>Icon yuklash:</label>
                        <input asp-for="Icon" type="file" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <img src="@ViewBag.iconPath" alt="user"
                             style="width: 100px; height: 100px; border-radius: 20%; object-fit: cover; margin-right: 10px;">
                    </div>
                </div>

                <div class="text-center mt-4">
                    <button type="submit" class="btn btn-primary px-4"><i class="fa fa-save me-2"></i>Yangilash</button>
                </div>
            </form>

            @if (TempData["successMessage"] != null)
            {
                <div id="success-alert" class="alert alert-success alert-dismissible fade show mt-4" role="alert">
                    <i class="fa fa-check-circle me-2"></i> @TempData["successMessage"]
                </div>
            }
            @if (TempData["errorMessage"] != null)
            {
                <div id="error-alert" class="alert alert-danger alert-dismissible fade show mt-4" role="alert">
                    <i class="fa fa-exclamation-circle me-2"></i> @TempData["errorMessage"]
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        setTimeout(function () {
            var success = document.getElementById('success-alert');
            if (success) {
                success.classList.remove('show');
                success.classList.add('fade');
                setTimeout(() => success.remove(), 500);
            }

            var error = document.getElementById('error-alert');
            if (error) {
                error.classList.remove('show');
                error.classList.add('fade');
                setTimeout(() => error.remove(), 500);
            }
        }, 3000);
    </script>
}