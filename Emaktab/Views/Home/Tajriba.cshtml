@{
    ViewData["Title"] = "Tajriba";
}

<style>

    body {
        background: #f4f7fb;
        font-family: 'Segoe UI', sans-serif;
    }

    .card {
        border-radius: 16px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        transition: 0.3s;
    }

        .card:hover {
            transform: translateY(-5px);
        }

    .card-header {
        border-radius: 16px 16px 0 0 !important;
        font-weight: 600;
        letter-spacing: 0.5px;
    }

    .table {
        border-radius: 12px;
        overflow: hidden;
    }

        .table thead {
            background: linear-gradient(90deg,#0d6efd,#0dcaf0);
            color: white;
        }

        .table tbody tr {
            transition: 0.3s;
        }

            .table tbody tr:hover {
                background: #eef5ff;
                transform: scale(1.01);
            }

    .badge {
        border-radius: 20px;
        font-size: 13px;
        padding: 6px 14px;
    }

    .total-badge {
        font-size: 16px;
        padding: 10px 25px;
        border-radius: 30px;
        background: linear-gradient(90deg,#198754,#20c997);
        color: white;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

    .chart-box {
        background: #fff;
        padding: 25px;
        border-radius: 50%;
        box-shadow: 0 8px 25px rgba(0,0,0,0.1);
        transition: 0.3s;
    }

        .chart-box:hover {
            transform: rotate(3deg) scale(1.05);
        }

    .chart-text {
        margin-top: 15px;
        font-size: 14px;
        color: #777;
    }

    .fade-in {
        animation: fadeIn 0.6s ease-in-out;
    }
    
</style>


<section class="content fade-in">
    <div class="container mt-4">

        <div class="card border-0">

            <div class="card-header text-white"
                 style="background: linear-gradient(90deg,#0d6efd,#0dcaf0);">
                <h4 class="mb-0">
                    <i class="fa fa-briefcase me-2"></i> Mening ish tajribam
                </h4>
            </div>

            <div class="card-body">
                <div class="row g-4">

                    <div class="col-md-7">

                        <table class="table table-hover table-bordered align-middle text-center shadow-sm">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Tashkilot</th>
                                    <th>Lavozim</th>
                                    <th>Davr</th>
                                    <th>Tajriba</th>
                                </tr>
                            </thead>

                            <tbody>
                                <tr>
                                    <td>1</td>
                                    <td>10-son maktab</td>
                                    <td>Informatika o‘qituvchisi</td>
                                    <td>2022 – 2024</td>
                                    <td>
                                        <span class="badge bg-info">2 yil</span>
                                    </td>
                                </tr>

                                <tr>
                                    <td>2</td>
                                    <td>TDTrU</td>
                                    <td>O‘qituvchi</td>
                                    <td>2024 – Hozirgacha</td>
                                    <td>
                                        <span class="badge bg-success">Davom etmoqda</span>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <div class="mt-4 text-center">
                            <span class="total-badge">
                                Jami tajriba: 3 yil
                            </span>
                        </div>

                    </div>

                    <div class="col-md-5 d-flex flex-column justify-content-center align-items-center">

                        <div class="chart-box">
                            <canvas id="chart" width="220" height="220"></canvas>
                        </div>

                        <p class="chart-text">
                            Tajriba taqsimoti
                        </p>

                    </div>

                </div>
            </div>

        </div>
    </div>
</section>


<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    const ctx = document.getElementById('chart');

    new Chart(ctx, {
        type: 'doughnut',
        data: {
            labels: ['10-son maktab', 'TDTrU'],
            datasets: [{
                data: [2, 1],
                backgroundColor: ['#0d6efd', '#20c997'],
                borderWidth: 3,
                hoverOffset: 10
            }]
        },
        options: {
            cutout: '70%',
            responsive: true,
            plugins: {
                legend: {
                    position: 'bottom',
                    labels: {
                        padding: 20,
                        font: {
                            size: 14
                        }
                    }
                }
            }
        }
    });
</script>