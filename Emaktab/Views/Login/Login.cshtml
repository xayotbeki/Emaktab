@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KPI | Platforma</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: Poppins;
            background: radial-gradient(circle at top, #1e293b, #020617);
            color: white;
            overflow-x: hidden;
        }

        .navbar {
            backdrop-filter: blur(10px);
            background: rgba(255,255,255,0.05);
            border-radius: 15px;
            margin: 20px;
        }

        .nav-link {
            color: #cbd5f5 !important;
            transition: 0.3s;
        }

            .nav-link:hover {
                color: white !important;
                transform: translateY(-2px);
            }

        .logo {
            font-weight: 700;
            font-size: 22px;
            color: #38bdf8;
        }

        .hero {
            min-height: 85vh;
            display: flex;
            align-items: center;
        }

        .title {
            font-size: 52px;
            font-weight: 700;
            line-height: 1.2;
        }

        .subtitle {
            color: #94a3b8;
            font-size: 18px;
            margin-top: 15px;
        }

        .btn-primary {
            background: linear-gradient(45deg,#3b82f6,#06b6d4);
            border: none;
            padding: 12px 22px;
            border-radius: 12px;
            transition: 0.3s;
        }

            .btn-primary:hover {
                transform: translateY(-3px);
                box-shadow: 0 10px 25px rgba(59,130,246,0.4);
            }

        .btn-outline-light {
            padding: 12px 22px;
            border-radius: 12px;
        }

        .glass {
            background: rgba(255,255,255,0.05);
            backdrop-filter: blur(15px);
            border-radius: 20px;
            padding: 35px;
            box-shadow: 0 10px 50px rgba(0,0,0,0.5);
        }

        .feature {
            display: flex;
            align-items: center;
            margin-bottom: 12px;
            color: #cbd5f5;
        }

            .feature i {
                margin-right: 10px;
                color: #38bdf8;
            }
    </style>
</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark px-4">
        <div class="container-fluid">
            <a class="navbar-brand logo" asp-controller="Home" asp-action="Index">
                KPI<span style="color:#94a3b8;">.uz</span>
            </a>

            <div class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="KPI">KPI tizimi</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Opportunities">Imkoniyatlar</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="About">Tizim haqida</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="FAQ">Savollar</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Contact">Bog‘lanish</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container hero">
        <div class="row w-100 align-items-center">

            <div class="col-md-6">
                <h1 class="title">
                    Tashkilot samaradorligini yangi bosqichga olib chiqing 🚀
                </h1>

                <p class="subtitle">
                    KPI UP platformasi orqali xodimlar faoliyatini nazorat qiling, tahlil qiling va rivojlantiring.
                </p>

                <div class="mt-4">
                    <a asp-controller="Login" asp-action="Index" class="btn btn-primary me-2">
                        Tizimga kirish
                    </a>

                    <a asp-controller="Login" asp-action="Register" class="btn btn-outline-light">
                        Ro‘yxatdan o‘tish
                    </a>
                </div>
            </div>

            <div class="col-md-6">
                <div class="glass">
                    <h4 class="mb-3">KPI Platforma</h4>

                    <div class="feature">
                        <i class="fa fa-chart-line"></i>
                        Real vaqt monitoring
                    </div>

                    <div class="feature">
                        <i class="fa fa-users"></i>
                        Xodimlar boshqaruvi
                    </div>

                    <div class="feature">
                        <i class="fa fa-file"></i>
                        Hujjatlar tizimi
                    </div>

                    <div class="feature">
                        <i class="fa fa-star"></i>
                        KPI baholash
                    </div>

                    <div class="feature">
                        <i class="fa fa-shield"></i>
                        Admin nazorat
                    </div>
                </div>
            </div>

        </div>
    </div>

</body>
</html>