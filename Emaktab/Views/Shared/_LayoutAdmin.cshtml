        .progressbar {
            margin: 0;
            padding: 0;
            counter-reset: step;
        }

            .progressbar li {
                list-style-type: none;
                width: 33%;
                float: left;
                font-size: 14px;
                position: relative;
                text-align: center;
                text-transform: uppercase;
                color: #7d7d7d;
            }

                .progressbar li:before {
                    width: 70px;
                    height: 40px;
                    content: counter(step);
                    counter-increment: step;
                    line-height: 40px;
                    border: 2px solid rgb(227, 235, 232);
                    display: block;
                    text-align: center;
                    margin: 0 auto 10px auto;
                    border-radius: 10%;
                    background-color: white;
                }

                .progressbar li.active {
                    color: green;
                    border-color: #55b776;
                }

                .progressbar li.finish {
                    color: #1e88e5;
                }

                .progressbar li.active:before {
