        .tools .nav-content {
            display: flex;
            align-items: center;
            justify-content: center;
            transform: rotate(-45deg);
        }

        .sidebar_mini_new .tools .nav-content .toggle-btn,
        .sidebar_mini_new .tools .nav-content span a {
            height: 60px;
            width: 60px;
            background: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            box-shadow: 0 0 20px rgba(0,0,0,0.2);
        }

        .sidebar_mini_new .tools .nav-content .toggle-btn {
            font-size: 35px;
            color: #0e2431;
            z-index: 100;
            cursor: pointer;
            transform: rotate(-225deg);
            transition: all 0.6s ease;
        }

        .sidebar_mini_new .tools.open .toggle-btn {
            transform: rotate(0deg);
        }

        .nav-content span {
            position: absolute;
            transition: all 0.6s ease;
            opacity: 0;
        }

        .sidebar_mini_new .tools.open .nav-content span {
            transform: rotate(calc(var(--i) * (360deg/6.7))) translateY(110px);
            opacity: 1;
            z-index: 9999999;
        }

        .sidebar_mini_new .tools .nav-content span a {
            text-decoration: none;
            transform: rotate(45deg);
            cursor: pointer;
        }

            .sidebar_mini_new .tools .nav-content span a i {
                font-size: 26px;
                color: #0e2431;
                transform: rotate(calc(var(--i) * (360deg/ -6.7)));
                opacity: 0.8;
                transition: 0.2s;
            }

            .sidebar_mini_new .tools .nav-content span a:hover i {
                opacity: 1;
            }

